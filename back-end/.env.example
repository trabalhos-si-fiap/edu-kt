# Edu Backend - environment variables example
# Copy this file to `.env` and adjust values. Never commit a real `.env`.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite path (relative to back-end/ unless absolute). Defaults to data/db.sqlite3.
DJANGO_DB_PATH=data/db.sqlite3
